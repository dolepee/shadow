{
  "name": "shadow",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "contracts:build": "forge build --root contracts",
    "contracts:test": "forge test --root contracts",
    "contracts:stress": "forge test --root contracts --match-contract ShadowFloatInvariantTest -vv",
    "contracts:deploy:arc": "cd contracts && forge script script/DeployShadowArc.s.sol:DeployShadowArc --rpc-url $ARC_RPC_URL --broadcast",
    "contracts:deploy:float": "cd contracts && forge script script/DeployShadowFloat.s.sol:DeployShadowFloat --rpc-url $ARC_RPC_URL --broadcast",
    "contracts:deploy:forum-canary": "cd contracts && forge script script/DeployForumCanary.s.sol:DeployForumCanary --rpc-url $ARC_RPC_URL --broadcast",
    "contracts:seed:arc": "cd contracts && forge script script/SeedShadowArc.s.sol:SeedShadowArc --rpc-url $ARC_RPC_URL --broadcast",
    "app:dev": "pnpm --dir app dev",
    "app:build": "pnpm --dir app build",
    "app:typecheck": "pnpm --dir app typecheck",
    "agent:intent": "pnpm --dir agent intent",
    "agent:close-position": "pnpm --dir agent close-position",
    "agent:topup-follower-b": "pnpm --dir agent topup-follower-b",
    "agent:pilot-execute": "pnpm --dir agent pilot-execute",
    "agent:headless-follower": "pnpm --dir agent headless-follower",
    "agent:typecheck": "pnpm --dir agent exec tsc --noEmit",
    "verify:slippage": "pnpm --dir agent verify-slippage",
    "float:proof": "node app/scripts/float-proof.mjs",
    "float:x402-proof": "node app/scripts/float-x402-proof.mjs",
    "float:external-spend": "node app/scripts/float-external-spend.mjs",
    "float:verify-live": "node app/scripts/float-verify-live.mjs",
    "float:score-proof": "node app/scripts/float-score-proof.mjs",
    "float:v2-sponsor-line": "node app/scripts/float-v2-sponsor-line.mjs",
    "float:v2-sponsored-proof": "node app/scripts/float-v2-sponsored-proof.mjs",
    "float:v2-bind-intent": "node app/scripts/float-v2-bind-intent.mjs",
    "float:v2-provider-delivery": "node app/scripts/float-v2-provider-delivery.mjs",
    "float:v2-verify-live": "node app/scripts/float-v2-verify-live.mjs",
    "float:autounderwrite": "node app/scripts/float-autounderwrite.mjs",
    "float:desk": "node app/scripts/float-desk.mjs",
    "float:loop": "node app/scripts/float-loop.mjs",
    "treasury:spike": "node app/scripts/treasury-operator-spike.mjs",
    "treasury:verify-live": "node app/scripts/treasury-verify-live.mjs",
    "forum:canary-verify": "node app/scripts/forum-canary-verify.mjs",
    "extract:addresses": "node scripts/extract-addresses.mjs"
  }
}
