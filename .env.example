ARC_RPC_URL=https://rpc.testnet.arc.network
# Optional: canonical Arc RPC used for reads/receipts when ARC_RPC_URL is a proxy that lags
ARC_PUBLIC_RPC_URL=https://rpc.testnet.arc.network
ARC_USDC=0x3600000000000000000000000000000000000000

# Use testnet-only keys. Never commit .env.
PRIVATE_KEY=
CAT_AGENT_PRIVATE_KEY=
LOBSTER_AGENT_PRIVATE_KEY=
FOLLOWER_A_PRIVATE_KEY=
FOLLOWER_B_PRIVATE_KEY=

# 6 decimals for ERC20 USDC, 18 decimals for ARCETH.
SEED_USDC_AMOUNT=5000000
SEED_ARCETH_AMOUNT=1000000000000000000

SHADOW_ARCETH=
SHADOW_AMM=
SHADOW_REGISTRY=
SHADOW_ROUTER=
SHADOW_PILOT_ATTESTOR=

# Lepton M1 local deploy/smoke config.
LEPTON_MIN_BOND_USDC=10000000
LEPTON_REGISTRY=
LEPTON_ATTESTOR=
LEPTON_ENFORCER=
LEPTON_VAULT_SINK=
LEPTON_ADAPTER=
LEPTON_SMOKE_ALLOW_USDC=1000000
LEPTON_SMOKE_DAILY_CAP_USDC=2000000
LEPTON_SMOKE_BLOCK_USDC=3000000

# Bankr LLM gateway (OpenAI-compatible). Set BANKR_LLM_KEY + LLM_REASONING_ENABLED=1
# on a publisher step to let the model pick amountUSDC, minBps, riskLevel, and
# rationale within the configured bounds. Falls back to env defaults if missing
# or the call fails. Get a key at https://bankr.bot.
BANKR_LLM_KEY=
BANKR_LLM_MODEL=deepseek-v3.2

# Public frontend config. These are safe to expose.
VITE_ARC_RPC_URL=
VITE_ARC_USDC=0x3600000000000000000000000000000000000000
VITE_SHADOW_ARCETH=
VITE_SHADOW_AMM=
VITE_SHADOW_REGISTRY=
VITE_SHADOW_ROUTER=
VITE_SHADOW_PILOT_ATTESTOR=
VITE_SHADOW_START_BLOCK=0
VITE_SHADOW_MANDATE_REGISTRY=
VITE_SHADOW_MANDATE_ATTESTOR=
VITE_SHADOW_BONDED_ENFORCER=
VITE_SHADOW_V4_STYLE_ADAPTER=

# Circle Modular Wallets (passkey + Gas Station paymaster).
# Create both at https://console.circle.com → Modular Wallets.
# Paymaster policy must be active on Arc Testnet for sponsored userOps.
VITE_CIRCLE_CLIENT_KEY=
VITE_CIRCLE_CLIENT_URL=

# Optional x402 reasoning preview. /api/reasoning remains public for the UI;
# /api/reasoning-x402 requires an Arc USDC EIP-3009 payment.
X402_USDC=0x3600000000000000000000000000000000000000
X402_PAY_TO=
X402_FACILITATOR_PRIVATE_KEY=
X402_REASONING_PRICE_ATOMIC=1000

# Circle Gateway per-mirror nanosettlement. Testnet only.
# GATEWAY_SETTLEMENT_PAY_TO can reuse X402_PAY_TO, but keeping it separate
# makes the receipt-fee rail explicit in Vercel env.
GATEWAY_SETTLEMENT_PAY_TO=
GATEWAY_NANOSETTLEMENT_FEE_ATOMIC=100
GATEWAY_WALLET_ADDRESS=0x0077777d7EBA4688BDeF3E311b846F25870A19B9
GATEWAY_FACILITATOR_URL=https://gateway-api-testnet.circle.com
# Local operator script only; never set as a public Vite var.
GATEWAY_PAYER_PRIVATE_KEY=
SHADOW_APP_URL=https://shadow-arc.vercel.app

# CCTP/Gateway follower funding acknowledgement.
CCTP_ATTESTATION_API_URL=https://iris-api-sandbox.circle.com
CCTP_BURN_TX=
CCTP_SOURCE_DOMAIN=
CCTP_FOLLOWER=
CCTP_EXPECTED_AMOUNT_ATOMIC=
