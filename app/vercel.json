{
  "framework": null,
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "shadow-two-opal.vercel.app" }],
      "destination": "https://shadow-arc.vercel.app/",
      "permanent": true
    },
    {
      "source": "/((?!\\.well-known).+)",
      "has": [{ "type": "host", "value": "shadow-two-opal.vercel.app" }],
      "destination": "https://shadow-arc.vercel.app/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/.well-known/webauthn",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/((?!api|assets|favicon|\\.well-known).*)", "destination": "/index.html" }
  ]
}
